SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
UPLOAD_BUCKET=dengue-uploads
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.vercel.app
# Optional for preview deployments:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Worker/runtime paths
DENGUARD_MASTER_DATA_CSV=intermediate/dengue_master_cleaned.csv
DENGUARD_OUT_ROOT=intermediate/runs
DENGUARD_POLICY_LOCAL_PERF_CSV=policies/local_model_performance_backtest_2022-12-26_3b3037b5.csv
# Optional:
# DENGUARD_INCOMING_MODE=incremental
# DENGUARD_CANON_CSV=

# Worker behavior
WORKER_POLL_SECONDS=15
# WORKER_RUN_ONCE=true
